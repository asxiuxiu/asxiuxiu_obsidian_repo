{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Conan Install",
            "type": "shell",
            "command": "conan",
            "args": [
                "install",
                ".",
                "--build=missing",
                "-pr:h", "gcc",
                "-pr:b", "gcc"
            ],
            "group": "build"
        },
        {
            "label": "Configure CMake",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build",
                "-G", "Ninja",
                "-DCMAKE_CXX_COMPILER=g++",
                "-DCMAKE_BUILD_TYPE=Release",
                {
                    "value": "-DCMAKE_TOOLCHAIN_FILE=build/Release/generators/conan_toolchain.cmake",
                    "quoting": "strong"
                }
            ],
            "group": "build",
            "dependsOn": "Conan Install"
        },
        {
            "label": "Build with Ninja",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "Configure CMake"
        }
    ]
}
