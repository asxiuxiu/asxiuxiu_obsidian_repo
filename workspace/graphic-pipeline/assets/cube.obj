# Simple unit cube
# Vertices
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# Faces (triangles)
# Back face (z = -0.5)
f 1 2 3
f 1 3 4
# Front face (z = 0.5)
f 5 7 6
f 5 8 7
# Bottom face (y = -0.5)
f 1 5 6
f 1 6 2
# Top face (y = 0.5)
f 3 7 8
f 3 8 4
# Left face (x = -0.5)
f 1 4 8
f 1 8 5
# Right face (x = 0.5)
f 2 6 7
