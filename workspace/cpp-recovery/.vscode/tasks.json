{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure CMake",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build",
                "-G", "Ninja",
                "-DCMAKE_CXX_COMPILER=g++"
            ],
            "group": "build",
            "options": {
                "env": {
                    "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
                }
            }
        },
        {
            "label": "Build with Ninja",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "Configure CMake",
            "options": {
                "env": {
                    "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
                }
            }
        },
        {
            "label": "Configure CMake with ASan",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build-asan",
                "-G", "Ninja",
                "-DCMAKE_CXX_COMPILER=g++",
                "-DENABLE_ASAN=ON"
            ],
            "group": "build",
            "options": {
                "env": {
                    "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
                }
            }
        },
        {
            "label": "Build with ASan",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-asan"
            ],
            "group": "build",
            "dependsOn": "Configure CMake with ASan",
            "options": {
                "env": {
                    "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
                }
            }
        }
    ]
}
